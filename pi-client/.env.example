# Lambda API エンドポイント（末尾スラッシュなし）
API_URL=https://xxxxxx.lambda-url.ap-northeast-1.on.aws

# POST /data 認証キー（GitHub Secrets の API_KEY と同じ値）
API_KEY=your-api-key-here

# SwitchBot CO2センサーのデバイス ID
DEVICE_ID=XXXXXXXX

# BLE MAC アドレスによるフィルタリング（任意）
# 複数の SwitchBot デバイスが存在する環境では設定を推奨
# 例: DEVICE_MAC=AA:BB:CC:DD:EE:FF
# DEVICE_MAC=

# スキャン間隔（秒）。デフォルト: 60
SCAN_INTERVAL=60

# 1 回のスキャン持続時間（秒）。デフォルト: 5
SCAN_DURATION=5
