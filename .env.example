# Switchbot API Credentials
# Get your token and secret from: https://support.switch-bot.com/hc/en-us/articles/12822710195351
VITE_SWITCHBOT_API_TOKEN=your_token_here
VITE_SWITCHBOT_SECRET=your_secret_here

# Optional: Device ID
# If you have multiple sensors, specify the device ID
VITE_SWITCHBOT_DEVICE_ID=your_device_id_here
